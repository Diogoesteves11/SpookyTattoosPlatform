# PostgreSQL Database
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# pgAdmin 4
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin_password

# .NET Backend Connection String (For internal Docker network use)
# Host is 'db' (matches the service name), not 'localhost'
ConnectionStrings__DefaultConnection="Host=db;Port=5432;Database=your_db_name;Username=your_db_user;Password=your_db_password"